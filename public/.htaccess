<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect www to non-www
  RewriteCond %{HTTP_HOST} ^www\.hitmandigital\.in [NC]
  RewriteRule ^(.*)$ https://hitmandigital.in/$1 [R=301,L]

  # Allow direct access to files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Fix Next.js static page routing (important for refresh issue)
  RewriteRule ^(.*)/$ $1/index.html [L,QSA]
  RewriteRule ^(.*)$ $1.html [L,QSA]

  # Custom 404 handling
  ErrorDocument 404 /404.html
</IfModule>

# Ensure robots can index the site
<IfModule mod_headers.c>
  Header set X-Robots-Tag "index, follow"
</IfModule>
